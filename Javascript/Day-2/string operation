
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
</head>
<body>
    <script>
        let school='Shreeyantra collage';
        let text =`Welcome to ${school}`;
        document.write(text + "<br>");
        let str="Hello";
        document.write(str.length + "<br>");
        
        let  cha = "javascript";
        document.write(cha[0] + "<br>");
        document.write(cha.charAt(4) + "<br>");
        let ca ="Hello";
        document.write(ca.toUpperCase() + "<br>");
        document.write(ca.toLowerCase() + "<br>");
        let first = "Shreeyantra";
        let second ="collage";
        let result=`${first} ${second}`;

        document.write(result + "<br>");
        let txt="I Love Javascript";
        document.write(txt.indexof("love") +"<br>" );
        document.write(txt.includes("html") +"<br>" );
         
        let ext="JavaScript";
        document.write(ext.slice(0,4)+"<br>");
        document.write(ext.substring(4,10)+"<br>");
        let rep="Hello world";
        document.write(rep.replaceALL("1","*")+ "<br>");

        let tr ="Hello";
        document.write(tr.trim()+ "<br>");

        let num="100";
        document.write(Number(num)+"<br>");
        document.write(parseInt(num)+"<br>");
        let nums=500;
        document.write(nums.toString());
        </script>
    </script>
</body>
</html>
